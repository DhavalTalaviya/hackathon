    {
      "type": "ComposedChart",
      "title": "Monthly Bookings vs Costs",
      "sql": "SELECT b.month AS month, b.booking_count, COALESCE(c.total_costs, 0) AS total_costs FROM (SELECT strftime('%Y-%m', date) AS month, COUNT(*) AS booking_count FROM bookings GROUP BY strftime('%Y-%m', date)) b LEFT JOIN (SELECT strftime('%Y-%m', date) AS month, SUM(amount) AS total_costs FROM costs GROUP BY strftime('%Y-%m', date)) c ON b.month = c.month ORDER BY b.month",
      "xAxisKey": "month",
